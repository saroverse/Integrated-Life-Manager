# ── Database ──────────────────────────────────────────────────────────────────
DATABASE_URL=sqlite+aiosqlite:///./ilm.db

# ── API Auth — REQUIRED ───────────────────────────────────────────────────────
DEVICE_API_TOKEN=***REMOVED***

# ── Backend server ────────────────────────────────────────────────────────────
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000
TIMEZONE=Europe/Berlin

# ── AI — V2: OpenClaw → Claude API ───────────────────────────────────────────
CLAUDE_API_KEY=***REMOVED***
CLAUDE_MODEL=claude-haiku-4-5-20251001

# OpenClaw local proxy (runs on port 18789, tried before Claude API for scheduled jobs)
OPENCLAW_URL=http://localhost:18790
OPENCLAW_GATEWAY_TOKEN=ilm-internal

# Groq — used by OpenClaw for cheap scheduled jobs (briefings, recaps)
GROQ_API_KEY=***REMOVED***
GROQ_MODEL=llama-3.1-8b-instant

# Ollama disabled in V2 (kept for reference)
# OLLAMA_URL=http://localhost:11434
# PREFERRED_AI_MODEL=mistral:7b-instruct
# FALLBACK_AI_MODEL=llama3.2:3b

# ── Zepp / Huami health sync ──────────────────────────────────────────────────
# Login-based auth is rate-limited — use static token instead (extract via mitmproxy)
ZEPP_APP_TOKEN=
ZEPP_USER_ID=
# Legacy (unused, kept for reference)
ZEPP_EMAIL=***REMOVED***
ZEPP_PASSWORD=***REMOVED***

# ── Firebase push notifications — optional ───────────────────────────────────
FIREBASE_CREDENTIALS_PATH=./firebase-service-account.json
