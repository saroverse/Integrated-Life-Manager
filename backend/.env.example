# ── Database ──────────────────────────────────────────────────────────────────
DATABASE_URL=sqlite+aiosqlite:///./ilm.db

# ── API Auth — REQUIRED ───────────────────────────────────────────────────────
# Generate with: python3 -c "import secrets; print(secrets.token_hex(32))"
DEVICE_API_TOKEN=change-this-to-a-random-secret

# ── Backend server ────────────────────────────────────────────────────────────
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000
TIMEZONE=Europe/Berlin

# ── AI — V2: OpenClaw → Groq (cheap, scheduled jobs) + Claude API (chat) ─────

# Claude API — used for user-facing chat (complex queries)
CLAUDE_API_KEY=
CLAUDE_MODEL=claude-haiku-4-5-20251001

# OpenClaw local proxy — forwards to Groq for briefings/recaps (port 18790)
OPENCLAW_URL=http://localhost:18790
OPENCLAW_GATEWAY_TOKEN=ilm-internal

# Groq — used by OpenClaw for cheap scheduled jobs (briefings, recaps)
# Free tier at console.groq.com — model: llama-3.1-8b-instant
GROQ_API_KEY=
GROQ_MODEL=llama-3.1-8b-instant

# Ollama disabled in V2 (local LLM, replaced by OpenClaw→Groq)
# OLLAMA_URL=http://localhost:11434
# PREFERRED_AI_MODEL=mistral:7b-instruct
# FALLBACK_AI_MODEL=llama3.2:3b

# ── Zepp / Huami health sync — REQUIRED for watch data ───────────────────────
# Option A: static app token (extract via mitmproxy from the Zepp app)
ZEPP_APP_TOKEN=
ZEPP_USER_ID=
# Option B: email/password login (may be rate-limited by Zepp)
ZEPP_EMAIL=
ZEPP_PASSWORD=

# ── Firebase push notifications — optional ───────────────────────────────────
# Path to downloaded service account JSON from Firebase Console
FIREBASE_CREDENTIALS_PATH=./firebase-service-account.json
