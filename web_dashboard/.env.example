# ── Database ──────────────────────────────────────────────────────────────────
DATABASE_URL=sqlite+aiosqlite:///./ilm.db

# ── API Auth — REQUIRED ───────────────────────────────────────────────────────
# Generate with: python3 -c "import secrets; print(secrets.token_hex(32))"
DEVICE_API_TOKEN=change-this-to-a-random-secret

# ── Backend server ────────────────────────────────────────────────────────────
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000
TIMEZONE=Europe/Berlin

# ── AI — at least one provider required for summaries/chat ───────────────────
OLLAMA_URL=http://localhost:11434
PREFERRED_AI_MODEL=mistral:7b-instruct
FALLBACK_AI_MODEL=llama3.2:3b

# Claude API fallback (optional)
CLAUDE_API_KEY=

# OpenClaw proxy (optional, tried first before Ollama)
OPENCLAW_URL=http://localhost:18789
OPENCLAW_GATEWAY_TOKEN=

# ── Zepp / Huami health sync — REQUIRED for watch data ───────────────────────
ZEPP_EMAIL=
ZEPP_PASSWORD=

# ── Firebase push notifications — optional ───────────────────────────────────
# Path to downloaded service account JSON from Firebase Console
FIREBASE_CREDENTIALS_PATH=./firebase-service-account.json
